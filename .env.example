# Client-side (safe to expose — must be prefixed EXPO_PUBLIC_ to reach the app bundle)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Only needed if the Expo Router API routes (app/api/**) aren't served from the
# same origin the app is running from — e.g. a native dev build pointed at a
# deployed API. Leave unset for local dev and web.
# EXPO_PUBLIC_API_URL=https://your-deployed-app.example.com

# Optional — raises Google Books' per-IP rate limit (keyless calls 429 quickly).
# Search still works without it, just more prone to throttling.
EXPO_PUBLIC_GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Server-only (used by app/api/push/send+api.ts — never prefix this with EXPO_PUBLIC_)
# Bypasses Row-Level Security entirely — keep this out of the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# e2e/ (Playwright) — a real, non-admin test account. Never used by the app
# itself, only by the test suite (npm run test:e2e).
E2E_EMAIL=test-account@example.com
E2E_PASSWORD=your-test-password
